{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "catalog",
  "description": "특정 규제 보거나 가이드라인의 최상위 메타데이터 및 제도의 식별 정보를 정의하는 마스터 스키마",
  "type": "object",
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "규제 정의 원장의 전역 고유 식별 주소. RFC 8141 문법을 준수하며 영문 소문자만 허용함. 포맷: urn:grc:{region}:{framework}:{version}"
    },
    "catalog_name": {
      "type": "string",
      "description": "인증제도 또는 보안 규격의 공식 약어 명칭 (예: csap, isms-p, iso27001)"
    },
    "catalog_version": {
      "type": "string",
      "pattern": "^[0-9]{4}r[0-9]{2}$",
      "description": "행정적 개정 연도와 차수를 결합하여 단조 정렬이 가능하도록 설계된 버전 코드 (예: 2026r01)"
    },
    "title": {
      "type": "string",
      "description": "규제 기관이 발간한 고시 표준 가이드라인 해설서의 공식 전체 타이틀 텍스트"
    },
    "region_code": {
      "type": "string",
      "pattern": "^(?:kr|us|global)$",
      "description": "ISO 3166-1 기준의 관할권 국가 코드 또는 전 세계 통용 규격일 경우 global 마킹 (완전 소문자 강제)"
    },
    "publisher": {
      "type": "array",
      "items": { "type": "string" },
      "description": "해당 제도를 관할하고 공표한 주관 정부 부처 및 산하 심사 기관의 목록 명사 배열"
    },
    "catalog_type": {
      "type": "string",
      "enum": ["REGULATORY_FRAMEWORK", "IMPLEMENTATION_GUIDE", "INTERNAL_STANDARD"],
      "description": "제도의 행정학적 성격 분류"
    },
    "governing_law": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "해당 규제 제도의 발효 근거가 되는 상위 법률 및 시행령 명칭 배열 (국가 강제 규제가 아닐 경우 null 고정)"
    },
    "effective_date": {
      "type": "string",
      "format": "date",
      "description": "해당 판본의 규제가 법리적 혹은 행정적으로 실제 발효 및 시행된 공식 날짜 (YYYY-MM-DD)"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "SUPERSEDED", "DRAFT"],
      "description": "현재 스냅샷 데이터의 효력 상태"
    },
    "supersedes": {
      "type": ["string", "null"],
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "본 카탈로그가 대체한 직전 버전 카탈로그의 고유 catalog_id URN 주소"
    },
    "description": {
      "type": "string",
      "description": "해당 판본이 개정된 핵심 취지"
    },
    "extensions": {
      "type": "object",
      "properties": {
        "framework_meta": {
          "type": "array",
          "description": "제도별 특수 속성 배열 (name-value)",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
              "value": { "type": "string" }
            },
            "required": ["name", "value"],
            "additionalProperties": false
          }
        }
      },
      "required": ["framework_meta"],
      "additionalProperties": false
    }
  },
  "required": [
    "catalog_id",
    "catalog_name",
    "catalog_version",
    "title",
    "region_code",
    "publisher",
    "catalog_type",
    "effective_date",
    "status",
    "supersedes",
    "description",
    "extensions"
  ],
  "additionalProperties": false
}