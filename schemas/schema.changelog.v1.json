{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kisacloud.github.io/compliance-spec/schemas/schema.changelog.v1.json",
  "title": "changelog",
  "description": "한 제도의 두 판본(구버전 -> 신버전) 사이의 통제 단위 차분을 기록하는 스키마. '스냅샷 불변성' 원칙상 각 판본 catalog/control은 수정하지 않으므로, 판본 간 변경은 전적으로 이 차분 파일이 담는다. 핵심은 단순 상태 기록을 넘어, 구버전 기준으로 축적된 자동화 증적을 신버전 심사에서 어떻게 인정할지(evidence_transition_rule)를 선언하여 감사 추적성(Audit Trail) 단절을 방어하는 데 있다.",
  "type": "object",
  "properties": {
    "changelog_id": {
      "type": "string",
      "description": "변경로그 파일의 고유 식별 라벨. 관례상 구버전 URN과 신버전 URN을 '__'로 이어 생성하지만(예: urn:grc:kr:csap:2023r1__kr:csap:2026r1), 파싱 대상이 아니다. 판본 관계는 아래 source_catalog_id/target_catalog_id 원자 필드를 사용한다. 유일성만 보장하면 된다."
    },
    "source_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[1-9][0-9]*$",
      "description": "개정 전 구버전 카탈로그의 고유 URN"
    },
    "target_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[1-9][0-9]*$",
      "description": "개정 후 신버전 카탈로그의 고유 URN"
    },
    "changes": {
      "type": "array",
      "description": "구버전 대비 변경이 발생한 통제 항목들의 차분 행 배열",
      "items": {
        "type": "object",
        "properties": {
          "source_control_id": {
            "type": ["string", "null"],
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[1-9][0-9]*:control:[a-z0-9._-]+$",
            "description": "구버전 통제 항목의 control_id. 신규 신설(status_code=NEW)인 경우 대응 원본이 없으므로 null."
          },
          "target_control_id": {
            "type": ["string", "null"],
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[1-9][0-9]*:control:[a-z0-9._-]+$",
            "description": "신버전 통제 항목의 control_id. 폐지(status_code=DEPRECATED)되어 신버전에 대응이 없으면 null."
          },
          "status_code": {
            "type": "string",
            "enum": ["UNCHANGED", "CHANGED", "NEW", "DEPRECATED"],
            "description": "차분 상태. UNCHANGED=동일(번호/문안 유지), CHANGED=문안 변경, NEW=신규 신설, DEPRECATED=폐지. 고위험 강화 등으로 통제가 추가되면 NEW, 기존 통제 문안이 강화되면 CHANGED로 기록한다."
          },
          "change_note": {
            "type": "string",
            "description": "개정 사유 및 변경 내용 해설"
          },
          "evidence_transition_rule": {
            "type": "object",
            "description": "구버전 기준으로 축적된 증적을 신버전 심사에서 인정하는 규칙. 자동화 심사가 판본을 넘나들 때 증적의 법적 효력 승계를 결정론적으로 판단하게 한다.",
            "properties": {
              "sufficiency_type": {
                "type": "string",
                "enum": ["FULL_CREDIT", "PARTIAL_CREDIT", "NO_CREDIT", "PENDING_REGULATORY_DECISION"],
                "description": "증적 인정 정도. FULL_CREDIT=구증적 전부 인정, PARTIAL_CREDIT=일부 인정, NO_CREDIT=재증적 필요, PENDING_REGULATORY_DECISION=규제 결정 대기."
              },
              "inheritance_allowed": {
                "type": "boolean",
                "description": "구버전 증적의 신버전 자동 승계 허용 여부"
              },
              "delta_description": {
                "type": "string",
                "description": "증적 관점에서 무엇이 달라졌는지에 대한 서술"
              }
            },
            "required": ["sufficiency_type", "inheritance_allowed", "delta_description"],
            "additionalProperties": false
          },
          "extensions": {
            "type": "object",
            "description": "개별 차분 행 단위의 가변 속성 격리 레이어",
            "properties": {
              "framework_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              },
              "tenant_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["framework_meta", "tenant_meta"],
            "additionalProperties": false
          }
        },
        "required": [
          "source_control_id",
          "target_control_id",
          "status_code",
          "change_note",
          "evidence_transition_rule",
          "extensions"
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "description": "변경로그 파일 자체에 부속되는 가변 속성 레이어",
      "properties": {
        "framework_meta": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
              "value": { "type": "string" }
            },
            "required": ["name", "value"],
            "additionalProperties": false
          }
        }
      },
      "required": ["framework_meta"],
      "additionalProperties": false
    }
  },
  "required": [
    "changelog_id",
    "source_catalog_id",
    "target_catalog_id",
    "changes",
    "extensions"
  ],
  "additionalProperties": false
}
