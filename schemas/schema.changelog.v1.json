{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "changelog",
  "description": "단일 프레임워크의 개정 타임라인(시계열 차분)을 관리하며, 변경 관리에 따른 구형 증적의 법적 효력 유효 승계 규칙을 강제하는 스키마",
  "type": "object",
  "properties": {
    "changelog_id": {
      "type": "string",
      "description": "변경로그 파일 자체의 고유 식별자. 구버전 카탈로그 ID와 신버전 카탈로그 ID 문자열을 합성"
    },
    "source_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "개정 전 구버전 카탈로그의 고유 URN 주소 포인터"
    },
    "target_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "개정 후 현신버전 카탈로그의 고유 URN 주소 포인터"
    },
    "changes": {
      "type": "array",
      "description": "구버전 대비 변경이 발생한 통제 항목 조항들의 차분 행렬 목록 배열",
      "items": {
        "type": "object",
        "properties": {
          "source_control_id": {
            "type": ["string", "null"],
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:control:[a-z0-9._-]+$",
            "description": "개정 전 구버전 통제 항목의 개별 고유 URN 주소. (:control: 네임스페이스 동치화)"
          },
          "target_control_id": {
            "type": ["string", "null"],
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:control:[a-z0-9._-]+$",
            "description": "개정 후 현버전 통제 항목의 개별 고유 URN 주소. (:control: 네임스페이스 동치화)"
          },
          "status_code": {
            "type": "string",
            "enum": ["UNCHANGED", "CHANGED", "NEW", "DEPRECATED"],
            "description": "기계 연산용 상태 제어 코드"
          },
          "change_note": {
            "type": "string",
            "description": "행정 및 기술 규제 조항 문면의 개정 사유문 해설"
          },
          "evidence_transition_rule": {
            "type": "object",
            "description": "구버전 고정 자산 증적 로그를 신버전 심사 시 어떻게 법적으로 인정할 것인가에 대한 규칙",
            "properties": {
              "sufficiency_type": {
                "type": "string",
                "enum": ["FULL_CREDIT", "PARTIAL_CREDIT", "NO_CREDIT", "PENDING_REGULATORY_DECISION"]
              },
              "inheritance_allowed": {
                "type": "boolean"
              },
              "delta_description": {
                "type": "string"
              }
            },
            "required": ["sufficiency_type", "inheritance_allowed", "delta_description"],
            "additionalProperties": false
          },
          "extensions": {
            "type": "object",
            "description": "개별 차분 행 단위에서 가동되는 제도별/기업별 확장 격리 레이어",
            "properties": {
              "framework_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              },
              "tenant_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["framework_meta", "tenant_meta"],
            "additionalProperties": false
          }
        },
        "required": [
          "source_control_id",
          "target_control_id",
          "status_code",
          "change_note",
          "evidence_transition_rule",
          "extensions"
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "description": "변경로그 마스터 원장 자체에 부속되는 행정 속성 데이터 레이어",
      "properties": {
        "framework_meta": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
              "value": { "type": "string" }
            },
            "required": ["name", "value"],
            "additionalProperties": false
          }
        }
      },
      "required": ["framework_meta"],
      "additionalProperties": false
    }
  },
  "required": [
    "changelog_id",
    "source_catalog_id",
    "target_catalog_id",
    "changes",
    "extensions"
  ],
  "additionalProperties": false
}