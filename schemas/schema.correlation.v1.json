{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "correlation",
  "description": "정부 고시 및 전문가 선언에 기반하여 상호 제도 간 동형 인정 및 정성적 연관 관계의 출처성(Provenance)을 통제하는 스키마",
  "type": "object",
  "properties": {
    "correlation_id": {
      "type": "string",
      "description": "상관관계 명세 파일 자체의 고유 식별자. 소스 카탈로그 ID와 타깃 카탈로그 ID의 텍스트를 조합하여 사출"
    },
    "source_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "상호 인정 판단의 기준(출발점)이 되는 주체 프레임워크의 고유 카탈로그 URN 포인터"
    },
    "target_catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "소스 컴플라이언스를 통해 면제받거나 비교 대상이 되는 타깃 프레임워크의 고유 카탈로그 URN 포인터"
    },
    "schema_version": {
      "type": "string",
      "description": "본 상관관계 명세가 따르는 설계도 버전 (예: v1)"
    },
    "mappings": {
      "type": "array",
      "description": "기준 조항과 타깃 조항 간의 선언적 상호 인정 관계 매트릭스 배열",
      "items": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:control:[a-z0-9._-]+$",
            "description": "기준이 되는 소스 통제 항목의 개별 고유 control_urn 주소 (:control: 네임스페이스 일치화)"
          },
          "target_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:control:[a-z0-9._-]+$",
            "description": "매핑 대상이 되는 타깃 통제 항목의 개별 고유 control_urn 주소 (:control: 네임스페이스 일치화)"
          },
          "mapping_type": {
            "type": "string",
            "enum": ["EQUIVALENT", "SUPERSET", "SUBSET", "PARTIAL", "RELATED", "NO_EQUIVALENT"],
            "description": "선언된 매핑 관계의 연산학적 논리 성격"
          },
          "provenance": {
            "type": "string",
            "enum": ["OFFICIAL_NOTICE", "EXPERT_REVIEWED", "AI_SUGGESTED"],
            "description": "미래 판단-AI의 환각 제어를 위해 데이터의 신뢰 출처 등급을 강제 분류하는 필드"
          },
          "verification_status": {
            "type": "string",
            "enum": ["VERIFIED", "DRAFT", "REJECTED"],
            "description": "출처성 자산의 데이터 신뢰 승인 라이프사이클 상태"
          },
          "evidence_ref": {
            "type": ["string", "null"],
            "description": "공식 팩트 앵커 텍스트 (관보 고시 번호, 보고서 서지 정보 등)"
          },
          "rationale": {
            "type": "string",
            "description": "규제 주체의 해석이나 AI의 추론 논거문 단락을 그대로 보존하는 운반 텍스트 필드"
          },
          "extensions": {
            "type": "object",
            "description": "개별 매핑 행 단위에서 가동되는 제도별/기업별 확장 격리 레이어",
            "properties": {
              "framework_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              },
              "tenant_meta": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["framework_meta", "tenant_meta"],
            "additionalProperties": false
          }
        },
        "required": [
          "source_id",
          "target_id",
          "mapping_type",
          "provenance",
          "verification_status",
          "evidence_ref",
          "rationale",
          "extensions"
        ],
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object",
      "description": "상관관계 마스터 원장 자체에 부속되는 행정 속성 데이터 레이어",
      "properties": {
        "framework_meta": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
              "value": { "type": "string" }
            },
            "required": ["name", "value"],
            "additionalProperties": false
          }
        }
      },
      "required": ["framework_meta"],
      "additionalProperties": false
    }
  },
  "required": [
    "correlation_id",
    "source_catalog_id",
    "target_catalog_id",
    "schema_version",
    "mappings",
    "extensions"
  ],
  "additionalProperties": false
}