{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "control",
  "description": "단일 카탈로그 스냅샷에 종속되며, 기계적 무결성과 원자성을 확보한 순수 정형 통제 항목들의 집합 배열 명세의 틀",
  "type": "object",
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "본 파일 내부의 모든 통제 항목들이 종속되는 최상위 카탈로그 원장의 마스터 고유 식별 URN 포인터"
    },
    "schema_version": {
      "type": "string",
      "description": "본 정형 통제 항목 JSON 파일이 준수하는 스키마 버전의 명사 (예: v1)"
    },
    "controls": {
      "type": "array",
      "description": "카탈로그 하위의 세부 점검 및 통제 기준 객체들을 담은 수평 평탄화 배열",
      "items": {
        "type": "object",
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:control:[a-z0-9._-]+$",
            "description": "통제 항목 개별 객체의 지구상 전역 고유 식별 주소"
          },
          "catalog_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
            "description": "본 통제 항목이 소속된 부모 카탈로그의 고유 URN"
          },
          "control_no": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$",
            "description": "통제 항목의 고유 번호 (예: 1.1.1, 1.1.1_a). 복합 요구사항 분할 시 언더바(_) 사용을 권장함"
          },
          "base_no": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$",
            "description": "행정 고시 상의 공식 조항 번호. 조건부 행 분할(Row Splitting) 시 파생 항목들을 논리적으로 그룹핑(GROUP BY)하기 위한 기준 키"
          },
          "parent_no": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9._-]+$",
            "description": "계층 구조를 역추적하기 위한 상위 통제 항목 번호. 최상위 통제일 경우 null 지정"
          },
          "parent_title": {
            "type": ["string", "null"],
            "description": "상위 통제 항목(그룹/도메인 등)의 명칭. 기계 연산 및 AI 컨텍스트 유지를 위한 반정규화(Denormalization) 필드"
          },
          "domain_no": {
            "type": ["string", "null"],
            "description": "해당 통제가 속한 최상위 대분류 영역 또는 도메인의 고유 번호"
          },
          "domain_title": {
            "type": ["string", "null"],
            "description": "해당 통제가 속한 최상위 대분류 영역 또는 도메인의 공식 명칭"
          },
          "title": { "type": "string", "description": "통제 항목의 공식 제목 및 명칭" },
          "statement": { "type": "string", "description": "기계적 이진 판단(Pass/Fail)이 가능하도록 원자적으로 분해된 통제 요구사항 평문" },
          "extensions": {
            "type": "object",
            "properties": {
              "framework_meta": {
                "type": "array",
                "description": "정부 고시/기관 지정 행정 속성 데이터 배열",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              },
              "tenant_meta": {
                "type": "array",
                "description": "기업 자체 운영/인프라 매핑 데이터 배열",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["framework_meta", "tenant_meta"],
            "additionalProperties": false
          }
        },
        "required": [
          "control_id",
          "catalog_id",
          "control_no",
          "base_no",
          "parent_no",
          "parent_title",
          "domain_no",
          "domain_title",
          "title",
          "statement",
          "extensions"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["catalog_id", "schema_version", "controls"],
  "additionalProperties": false
}