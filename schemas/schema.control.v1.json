{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "control",
  "description": "단일 카탈로그 스냅샷에 종속되며, 기계적 무결성과 원자성을 확보한 순수 정형 통제 항목들의 집합 배열 명세의 틀",
  "type": "object",
  "properties": {
    "catalog_id": {
      "type": "string",
      "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$",
      "description": "본 파일 내부의 모든 통제 항목들이 종속되는 최상위 카탈로그 원장의 마스터 고유 식별 URN 포인터"
    },
    "schema_version": {
      "type": "string",
      "description": "본 정형 통제 항목 JSON 파일이 준수하는 스키마 버전의 명사 (예: v1)"
    },
    "controls": {
      "type": "array",
      "description": "카탈로그 하위의 세부 점검 및 통제 기준 객체들을 담은 수평 평탄화 배열",
      "items": {
        "type": "object",
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}:[a-z0-9._-]+$",
            "description": "통제 항목 개별 객체의 지구상 전역 고유 식별 주소"
          },
          "catalog_id": {
            "type": "string",
            "pattern": "^urn:grc:(?:[a-z]{2}|global):[a-z0-9-]+:[0-9]{4}r[0-9]{2}$"
          },
          "control_no": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$"
          },
          "parent_no": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9._-]+$"
          },
          "domain": { "type": "string" },
          "title": { "type": "string" },
          "statement": { "type": "string" },
          "extensions": {
            "type": "object",
            "properties": {
              "framework_meta": {
                "type": "array",
                "description": "정부 고시/기관 지정 행정 속성 데이터 배열",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              },
              "tenant_meta": {
                "type": "array",
                "description": "기업 자체 운영/인프라 매핑 데이터 배열",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
                    "value": { "type": "string" }
                  },
                  "required": ["name", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["framework_meta", "tenant_meta"],
            "additionalProperties": false
          }
        },
        "required": [
          "control_id",
          "catalog_id",
          "control_no",
          "parent_no",
          "domain",
          "title",
          "statement",
          "extensions"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["catalog_id", "schema_version", "controls"],
  "additionalProperties": false
}